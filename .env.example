# Neon Postgres connection string
DATABASE_URL=

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Market data (free tier)
FINNHUB_API_KEY=
COINGECKO_API_KEY=your-coingecko-api-key
MARKETAUX_API_KEY=

# LLM
ANTHROPIC_API_KEY=

# AI Portfolio — automated trading (Phase 1: crypto)
# OKX V5 (BTC/ETH/SOL spot). Set OKX_DEMO=1 to route to OKX demo trading.
OKX_API_KEY=your-okx-api-key
OKX_API_SECRET=your-okx-api-secret
OKX_API_PASSPHRASE=your-okx-passphrase
OKX_DEMO=1
# Hyperliquid (HYPE). Set HYPERLIQUID_TESTNET=1 for testnet.
HYPERLIQUID_ACCOUNT_ADDRESS=0xYourWalletAddress
HYPERLIQUID_PRIVATE_KEY=0xYourPrivateKey
HYPERLIQUID_TESTNET=0xYourTestnetPrivateKey
# Secures the DCA cron endpoint (Vercel Cron sends this as a Bearer token).
CRON_SECRET=your-cron-secret
